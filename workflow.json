{
  "name": "ai-lead-qualification-workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hubspot-lead",
        "responseMode": "responseNode"
      },
      "name": "Webhook — New Lead",
      "type": "n8n-nodes-base.webhook"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK"
      },
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook"
    },
    {
      "parameters": {
        "fields": {
          "values": [
            { "name": "firstName", "stringValue": "={{ $json.body.body.properties.firstname }}" },
            { "name": "lastName", "stringValue": "={{ $json.body.body.properties.lastname }}" },
            { "name": "email", "stringValue": "={{ $json.body.body.properties.email }}" },
            { "name": "company", "stringValue": "={{ $json.body.body.properties.company }}" },
            { "name": "website", "stringValue": "={{ $json.body.body.properties.website }}" },
            { "name": "contactId", "stringValue": "={{ $json.body.objectId }}" }
          ]
        }
      },
      "name": "Set Fields",
      "type": "n8n-nodes-base.set"
    },
    {
      "parameters": {
        "url": "={{ $json.website.startsWith('http') ? $json.website : 'https://' + $json.website }}"
      },
      "name": "Scrape Website",
      "type": "n8n-nodes-base.httpRequest"
    },
    {
      "parameters": {
        "modelId": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a B2B lead qualification expert. Return JSON with score and insights."
            },
            {
              "content": "=Company: {{$json.company}}\nWebsite: {{$json.text}}"
            }
          ]
        },
        "jsonOutput": true
      },
      "name": "OpenAI — Analyse Lead",
      "type": "@n8n/n8n-nodes-langchain.openAi"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "https://api.hubapi.com/crm/v3/objects/contacts/{{$json.contactId}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_HUBSPOT_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "name": "HubSpot Update",
      "type": "n8n-nodes-base.httpRequest"
    },
    {
      "parameters": {
        "operation": "create",
        "base": "YOUR_AIRTABLE_BASE_ID",
        "table": "YOUR_TABLE_NAME"
      },
      "name": "Airtable — Log Lead",
      "type": "n8n-nodes-base.airtable"
    }
  ]
}
