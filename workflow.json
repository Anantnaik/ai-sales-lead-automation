        "jsonBody": "={{ {\n  properties: {\n    hs_lead_status: \"IN_PROGRESS\",\n    lifecyclestage: \"lead\",\n    hs_content_membership_notes: \"🔥 HOT LEAD — Score: \" + $json.score + \"/100\\n\\nIndustry: \" + $json.industry + \"\\nSize: \" + $json.companySize + \"\\n\\nPain Points:\\n\" + $json.painPoints.join('\\n') + \"\\n\\nAutomation Opportunities:\\n\" + $json.automationOpportunities.join('\\n') + \"\\n\\nReason: \" + $json.scoreReason\n  }\n} }}",
